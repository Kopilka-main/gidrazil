---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const categories = [
  {
    title: 'Мойка кузова',
    items: [
      { name: 'Экспресс-мойка', desc: 'Кузов + стёкла', sedan: 400, suv: 500, jeep: 600 },
      { name: 'Комплексная мойка', desc: 'Кузов, диски, стёкла, чернение', sedan: 700, suv: 900, jeep: 1100 },
      { name: 'Мойка двигателя', desc: 'С обезжириванием', sedan: 800, suv: 1000, jeep: 1200 },
      { name: 'Мойка днища', desc: 'С прочисткой арок', sedan: 600, suv: 800, jeep: 1000 },
    ],
  },
  {
    title: 'Химчистка салона',
    items: [
      { name: 'Экспресс-уборка', desc: 'Пылесос + пластик + стёкла', sedan: 1500, suv: 1800, jeep: 2100 },
      { name: 'Химчистка сидений', desc: 'Ткань или кожа', sedan: 4000, suv: 4500, jeep: 5000 },
      { name: 'Полная химчистка', desc: 'Всё, включая потолок и багажник', sedan: 7000, suv: 8500, jeep: 10000 },
    ],
  },
  {
    title: 'Защитные покрытия',
    items: [
      { name: 'Полироль кузова', desc: 'Защита на 1-2 месяца', sedan: 2500, suv: 3000, jeep: 3500 },
      { name: 'Жидкое стекло', desc: 'Защита на 6 месяцев', sedan: 5000, suv: 6000, jeep: 7000 },
      { name: 'Керамика', desc: 'Защита на 1-2 года', sedan: 25000, suv: 30000, jeep: 35000 },
    ],
  },
];
---
<BaseLayout title="Цены — Гидразил">
  <section class="page-header">
    <div class="container">
      <h1>Цены</h1>
      <p class="lead">Прозрачное ценообразование. Цена зависит от размера машины — седан, кроссовер или внедорожник.</p>
    </div>
  </section>

  <section>
    <div class="container">
      {categories.map(cat => (
        <div class="category">
          <h2>{cat.title}</h2>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Услуга</th>
                  <th class="num-col">Седан</th>
                  <th class="num-col">Кроссовер</th>
                  <th class="num-col">Внедорожник</th>
                </tr>
              </thead>
              <tbody>
                {cat.items.map(item => (
                  <tr>
                    <td>
                      <div class="name">{item.name}</div>
                      <div class="desc">{item.desc}</div>
                    </td>
                    <td class="num-col">{item.sedan} ₽</td>
                    <td class="num-col">{item.suv} ₽</td>
                    <td class="num-col">{item.jeep} ₽</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      ))}

      <div class="note">
        Цены указаны в рублях. Для постоянных клиентов — система скидок до 20%.
        Возможны скидки на пакеты услуг. Подробности — у администратора.
      </div>

      <div style="text-align: center; margin-top: 48px;">
        <a href={`${base}/contacts`} class="btn">Записаться сейчас</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: 80px 0 40px;
    background: radial-gradient(circle at 50% 0%, rgba(56, 189, 248, 0.1), transparent 60%);
  }
  .lead {
    color: var(--text-dim);
    font-size: 18px;
    margin-top: 16px;
    max-width: 640px;
  }
  .category { margin-bottom: 48px; }
  .table-wrap {
    overflow-x: auto;
    background: var(--surface);
    border-radius: var(--radius);
    border: 1px solid var(--border);
  }
  table {
    width: 100%;
    border-collapse: collapse;
  }
  th, td {
    padding: 18px 20px;
    text-align: left;
    border-bottom: 1px solid var(--border);
  }
  tr:last-child td { border-bottom: none; }
  th {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: var(--bg-2);
  }
  .num-col { text-align: right; white-space: nowrap; }
  td.num-col { font-weight: 600; }
  .name { font-weight: 600; margin-bottom: 4px; }
  .desc { font-size: 14px; color: var(--text-dim); }
  .note {
    padding: 20px 24px;
    background: var(--surface);
    border-radius: var(--radius);
    border: 1px solid var(--border);
    color: var(--text-dim);
    font-size: 15px;
    margin-top: 32px;
  }
</style>
