---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Placeholder работы — потом заменим на реальные фото клиента
const works = [
  { title: 'BMW X5 — комплексная мойка', tag: 'Кузов', emoji: '🚙' },
  { title: 'Mercedes E-Class — химчистка', tag: 'Салон', emoji: '🚗' },
  { title: 'Toyota Land Cruiser — керамика', tag: 'Защита', emoji: '🚙' },
  { title: 'Audi A6 — полная детейлинг', tag: 'Детейлинг', emoji: '🏎' },
  { title: 'Range Rover — мойка днища', tag: 'Кузов', emoji: '🚙' },
  { title: 'Porsche Cayenne — жидкое стекло', tag: 'Защита', emoji: '🏎' },
];
---
<BaseLayout title="Портфолио — Гидразил">
  <section class="page-header">
    <div class="container">
      <h1>Портфолио</h1>
      <p class="lead">Наши работы. Фото «до» и «после» — реальные результаты на реальных машинах клиентов.</p>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="grid">
        {works.map(w => (
          <article class="card">
            <div class="thumb">
              <span class="emoji">{w.emoji}</span>
              <span class="tag">{w.tag}</span>
            </div>
            <div class="card-body">
              <h3>{w.title}</h3>
              <p class="muted">До / После</p>
            </div>
          </article>
        ))}
      </div>

      <div style="text-align: center; margin-top: 48px;">
        <a href={`${base}/contacts`} class="btn">Хочу так же</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: 80px 0 40px;
    background: radial-gradient(circle at 50% 0%, rgba(129, 140, 248, 0.1), transparent 60%);
  }
  .lead {
    color: var(--text-dim);
    font-size: 18px;
    margin-top: 16px;
    max-width: 640px;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }
  .card {
    background: var(--surface);
    border-radius: var(--radius);
    border: 1px solid var(--border);
    overflow: hidden;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }
  .card:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
  }
  .thumb {
    position: relative;
    aspect-ratio: 4 / 3;
    background: linear-gradient(135deg, rgba(56, 189, 248, 0.1), rgba(129, 140, 248, 0.1));
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .emoji { font-size: 80px; opacity: 0.9; }
  .tag {
    position: absolute;
    top: 16px;
    left: 16px;
    padding: 4px 12px;
    background: rgba(11, 15, 26, 0.7);
    backdrop-filter: blur(6px);
    border-radius: 999px;
    font-size: 12px;
    font-weight: 500;
    color: var(--accent);
  }
  .card-body { padding: 20px; }
  .card-body h3 { margin-bottom: 4px; font-size: 17px; }
  .muted { color: var(--text-dim); font-size: 14px; }
</style>
