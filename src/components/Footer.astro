---
const year = new Date().getFullYear();
---
<footer>
  <div class="container footer-inner">
    <div>
      <div class="brand">гидразил</div>
      <p class="muted">Профессиональная автомойка. Работаем без выходных.</p>
    </div>
    <div class="contacts">
      <a href="tel:+70000000000">+7 (000) 000-00-00</a>
      <a href="mailto:hello@gidrazil.ru">hello@gidrazil.ru</a>
      <span class="muted">г. Город, ул. Улица, 1</span>
    </div>
  </div>
  <div class="container copy">
    © {year} гидразил. Все права защищены.
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border);
    padding: 48px 0 24px;
    background: var(--bg-2);
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    margin-bottom: 32px;
  }
  .brand {
    font-size: 20px;
    font-weight: 800;
    margin-bottom: 8px;
  }
  .muted { color: var(--text-dim); }
  .contacts {
    display: flex;
    flex-direction: column;
    gap: 8px;
    justify-self: end;
    text-align: right;
  }
  .copy {
    padding-top: 24px;
    border-top: 1px solid var(--border);
    color: var(--text-dim);
    font-size: 14px;
  }
  @media (max-width: 640px) {
    .footer-inner { grid-template-columns: 1fr; }
    .contacts { justify-self: start; text-align: left; }
  }
</style>
