---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Услуга — ГИДРАЗИЛ</title>
<link rel="icon" type="image/png" href={`${base}/assets/img/favicon.png`} />
<link rel="apple-touch-icon" href={`${base}/assets/img/apple-touch-icon.png`} />
<link rel="stylesheet" href={`${base}/assets/css/styles.css`} />
</head>
<body>

<!-- ─────────────────────────  HEADER  ───────────────────────── -->
<header class="site-header">
  <div class="shell-wide row">
    <a class="logo" href={`${base}/`} aria-label="Гидразил — на главную">
      <img class="logo-emblem" src={`${base}/assets/img/logo-mark.png`} alt="" aria-hidden="true" />
      гидразил
    </a>

    <nav class="main-nav" aria-label="Основная навигация">
      <a href={`${base}/#about`}>о нас</a>
      <a href={`${base}/#services`}>услуги</a>
      <a href={`${base}/#pricing`}>цены</a>
      <a href={`${base}/#works`}>наши работы</a>
    </nav>

    <div class="header-actions">
      <a class="phone-link" href="tel:+79995516777">
        <span class="dot" aria-hidden="true"></span>
        +7 999 551 6777
      </a>
      <a class="btn btn-primary btn-sm arrow-after" href={`${base}/#booking`}>Запись</a>
    </div>
  </div>
</header>

<main data-service-page>

  <!-- ─────────────────────────  HERO  ───────────────────────── -->
  <section class="svc-hero">
    <div class="shell-wide">
      <nav class="crumbs" aria-label="Хлебные крошки">
        <a href={`${base}/`}>главная</a>
        <span class="sep">·</span>
        <a href={`${base}/#services`}>услуги</a>
        <span class="sep">·</span>
        <span data-crumb-name>—</span>
      </nav>

      <div style="display:flex;align-items:baseline;gap:24px;margin-bottom:12px;flex-wrap:wrap">
        <span class="mono" style="font-size:14px;color:var(--text-3);letter-spacing:0.04em">УСЛУГА № <span data-svc-num>00</span></span>
        <span class="chip chip-accent">в работе сейчас 3 авто</span>
      </div>
      <h1 data-svc-title>ЗАГРУЗКА</h1>

      <div class="meta-row">
        <p class="lede" data-svc-short>Короткое описание услуги загружается.</p>
        <div class="meta-bit">
          <div class="v">от 1 день</div>
          <div class="l">срок работ</div>
        </div>
        <div class="meta-bit">
          <div class="v">5 лет</div>
          <div class="l">гарантия</div>
        </div>
        <a class="btn btn-accent btn-lg arrow-after" href={`${base}/#booking`}>Записаться</a>
      </div>
    </div>
  </section>

  <!-- ─────────────────────────  GALLERY  ───────────────────────── -->
  <section class="block tight">
    <div class="shell-wide">
      <div class="section-head">
        <div class="left">
          <div class="eyebrow">Фото работ <span class="dot">·</span> <span class="accent">примеры по этой услуге</span></div>
          <h2>Как это выглядит</h2>
        </div>
        <div class="right">
          <span class="caption">Примеры наших работ</span>
        </div>
      </div>

      <div class="svc-grid" data-svc-gallery></div>
    </div>
  </section>

  <!-- ─────────────────────────  BODY COPY  ───────────────────────── -->
  <section class="block">
    <div class="shell-wide">
      <div class="svc-body">
        <aside class="col-meta">
          <div class="eyebrow"><span class="accent">Как мы работаем</span></div>
          <h3 style="margin-top:8px">Один бокс — одна работа</h3>
          <p class="body-sm">
            Авто заезжает на персональный пост. Мастер ведёт работу с нуля до выдачи —
            без передачи смены, без параллельных задач. Все материалы — оригиналы,
            сертификаты по запросу прикладываем к расчёту.
          </p>
          <div style="display:flex;flex-direction:column;gap:6px;margin-top:8px">
            <span class="chip">✓ Сертификаты материалов</span>
            <span class="chip">✓ Фотоотчёт по этапам</span>
            <span class="chip">✓ Гарантия в письменном виде</span>
            <span class="chip">✓ Курьер ключа в пределах ТТК</span>
          </div>
        </aside>

        <div>
          <h3>Описание услуги</h3>
          <div data-svc-desc>
            <p style="margin-top:16px">
              Подробное описание услуги: что именно мы делаем, какие материалы
              используем и что входит в стоимость. Точный объём и цену подтверждаем
              после осмотра автомобиля.
            </p>
          </div>

          <div class="svc-list" style="margin-top:32px" data-svc-steps>
            <div class="row">
              <span class="n">01</span>
              <div class="t">
                <div class="title">Приёмка и фотофиксация</div>
                <div class="sub">Описываем состояние авто, фиксируем дефекты, согласовываем объём.</div>
              </div>
              <span class="v">20 мин</span>
            </div>
            <div class="row">
              <span class="n">02</span>
              <div class="t">
                <div class="title">Подготовка</div>
                <div class="sub">Мойка, обезжиривание, при необходимости — предварительная полировка.</div>
              </div>
              <span class="v">1–4 ч</span>
            </div>
            <div class="row">
              <span class="n">03</span>
              <div class="t">
                <div class="title">Основная работа</div>
                <div class="sub">Сам процесс по технологии производителя материала. Контроль освещения.</div>
              </div>
              <span class="v">от 4 ч</span>
            </div>
            <div class="row">
              <span class="n">04</span>
              <div class="t">
                <div class="title">Контроль и выдача</div>
                <div class="sub">Совместный осмотр под лампой, подписание акта, рекомендации.</div>
              </div>
              <span class="v">30 мин</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─────────────────────────  PRICE TEASER  ───────────────────────── -->
  <section class="block tight" style="background:var(--surface-2)">
    <div class="shell-wide">
      <div class="section-head">
        <div class="left">
          <div class="eyebrow">Прайс по этой услуге <span class="dot">·</span> <span class="accent">от размера S</span></div>
          <h2>Сколько стоит</h2>
        </div>
        <div class="right">
          <a class="btn btn-ghost arrow-after" href={`${base}/#pricing`}>Полный калькулятор</a>
        </div>
      </div>
      <div data-price-teaser></div>
    </div>
  </section>

  <!-- ─────────────────────────  CTA  ───────────────────────── -->
  <section class="block tight">
    <div class="shell-wide">
      <div class="svc-cta">
        <span class="eyebrow" style="color:rgba(255,255,255,0.6)"><span class="accent" style="color:#d7b16a">Записаться</span> <span class="dot">·</span> ответ в МАХ за 15 мин</span>
        <h3>Готовы — пишите. Сомневаетесь — приезжайте на бесплатный осмотр.</h3>
        <div class="row">
          <a class="btn btn-accent btn-lg arrow-after" href={`${base}/#booking`}>Записаться онлайн</a>
          <a class="btn btn-ghost btn-lg" href="tel:+79995516777" style="color:#fff;border-color:rgba(255,255,255,0.25)">+7 999 551 6777</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─────────────────────────  RELATED  ───────────────────────── -->
  <section class="block">
    <div class="shell-wide">
      <div class="section-head">
        <div class="left">
          <div class="eyebrow">Смежные услуги <span class="dot">·</span> <span class="accent">часто берут вместе</span></div>
          <h2>Дальше</h2>
        </div>
      </div>
      <div class="svc-rel" data-related></div>
    </div>
  </section>

</main>

<!-- ─────────────────────────  FOOTER  ───────────────────────── -->
<footer class="site-footer" id="contacts">
  <div class="shell-wide">
    <div class="grid">
      <div>
        <a class="logo" href={`${base}/`}>
          <img class="logo-emblem" src={`${base}/assets/img/logo-mark.png`} alt="" aria-hidden="true" />
          гидразил
        </a>
        <p class="body-sm" style="color:rgba(244,243,239,0.6);max-width:36ch;margin-top:18px">
          Студия детейлинга в Москве. Бережный уход, восстановление и защита автомобиля.
        </p>
      </div>

      <div>
        <h4>Контакты</h4>
        <ul>
          <li class="contact-line"><a href="tel:+79995516777">+7 999 551 6777</a></li>
          <li><a href="mailto:info@hydrazil.ru">info@hydrazil.ru</a></li>
          <li style="font-family:var(--mono);font-size:13px;color:rgba(244,243,239,0.6);margin-top:8px">Ежедневно 09:00 – 21:00</li>
        </ul>
      </div>

      <div>
        <h4>Мессенджеры</h4>
        <ul>
          <li>МАХ: <span style="font-family:var(--mono)">+7 901 343 69 36</span></li>
          <li>Telegram: <a href="https://t.me/HydraZIL" target="_blank" rel="noopener" style="font-family:var(--mono)">@HydraZIL</a></li>
        </ul>
      </div>

      <div>
        <h4>Где мы</h4>
        <div class="map" aria-label="Карта (плейсхолдер)">
          <div class="pin">
            <span class="ring" aria-hidden="true"></span>
            <span>Бульвар Братьев Весниных, 1</span>
            <span style="opacity:0.5;margin-top:2px">−1 этаж · заезд через КПП</span>
          </div>
        </div>
      </div>
    </div>

    <div class="bottom">
      <span>© <span data-year></span> гидразил</span>
      <span>ОГРН 1207700000000</span>
    </div>
  </div>
</footer>

<script is:inline define:vars={{ base }}>window.SITE_BASE = base;</script>
<script is:inline src={`${base}/assets/js/data.js`}></script>
<script is:inline src={`${base}/assets/js/main.js`}></script>
</body>
</html>
