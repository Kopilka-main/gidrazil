---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Контакты и запись — Гидразил">
  <section class="page-header">
    <div class="container">
      <h1>Контакты</h1>
      <p class="lead">Запишись на мойку — перезвоним в течение 15 минут и подберём удобное время.</p>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="grid">
        <div class="info">
          <h2>Где найти</h2>
          <div class="info-row">
            <div class="info-icon">📍</div>
            <div>
              <div class="info-label">Адрес</div>
              <div>г. Город, ул. Улица, 1</div>
            </div>
          </div>
          <div class="info-row">
            <div class="info-icon">📞</div>
            <div>
              <div class="info-label">Телефон</div>
              <a href="tel:+70000000000">+7 (000) 000-00-00</a>
            </div>
          </div>
          <div class="info-row">
            <div class="info-icon">✉️</div>
            <div>
              <div class="info-label">Email</div>
              <a href="mailto:hello@gidrazil.ru">hello@gidrazil.ru</a>
            </div>
          </div>
          <div class="info-row">
            <div class="info-icon">🕐</div>
            <div>
              <div class="info-label">Часы работы</div>
              <div>Без выходных, 8:00 — 22:00</div>
            </div>
          </div>
        </div>

        <form class="form" id="contact-form">
          <h2>Записаться онлайн</h2>
          <label>
            <span>Имя</span>
            <input type="text" name="name" required placeholder="Как к тебе обращаться?" />
          </label>
          <label>
            <span>Телефон</span>
            <input type="tel" name="phone" required placeholder="+7 (___) ___-__-__" />
          </label>
          <label>
            <span>Услуга</span>
            <select name="service">
              <option>Комплексная мойка</option>
              <option>Экспресс-мойка</option>
              <option>Химчистка салона</option>
              <option>Жидкое стекло</option>
              <option>Керамика</option>
              <option>Не знаю — посоветуйте</option>
            </select>
          </label>
          <label>
            <span>Комментарий <em>(необязательно)</em></span>
            <textarea name="comment" rows="3" placeholder="Желаемая дата и время, особые пожелания"></textarea>
          </label>
          <button type="submit" class="btn submit-btn">Отправить заявку</button>
          <div class="form-status" id="form-status"></div>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: 80px 0 40px;
    background: radial-gradient(circle at 50% 0%, rgba(56, 189, 248, 0.1), transparent 60%);
  }
  .lead {
    color: var(--text-dim);
    font-size: 18px;
    margin-top: 16px;
    max-width: 640px;
  }
  .grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 48px;
  }
  .info h2 { margin-bottom: 24px; }
  .info-row {
    display: flex;
    gap: 16px;
    padding: 16px 0;
    border-bottom: 1px solid var(--border);
  }
  .info-icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    background: var(--surface);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
  }
  .info-label {
    font-size: 13px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 4px;
  }
  .form {
    padding: 32px;
    background: var(--surface);
    border-radius: var(--radius);
    border: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .form h2 { margin-bottom: 8px; }
  label {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  label > span {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-dim);
  }
  label em {
    font-style: normal;
    color: var(--text-dim);
    font-weight: 400;
    font-size: 13px;
  }
  input, select, textarea {
    padding: 12px 14px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    color: var(--text);
    font-family: inherit;
    font-size: 15px;
    transition: border-color 0.15s ease;
  }
  input:focus, select:focus, textarea:focus {
    outline: none;
    border-color: var(--accent);
  }
  textarea { resize: vertical; min-height: 80px; }
  .submit-btn {
    margin-top: 8px;
    justify-content: center;
  }
  .form-status {
    margin-top: 4px;
    padding: 12px;
    border-radius: 10px;
    font-size: 14px;
    text-align: center;
    display: none;
  }
  .form-status.ok {
    display: block;
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.3);
    color: #4ade80;
  }
  .form-status.err {
    display: block;
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.3);
    color: #f87171;
  }
  @media (max-width: 768px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('form-status');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!status) return;
    const data = new FormData(form);
    const payload = Object.fromEntries(data.entries());

    status.className = 'form-status';
    status.textContent = 'Отправляем...';
    status.classList.add('ok');

    // TODO: здесь будет запрос к Cloudflare Worker, который отправит сообщение в Telegram админу.
    // Пока что просто симулируем успех.
    console.log('Заявка:', payload);

    setTimeout(() => {
      status.textContent = '✓ Спасибо! Мы перезвоним в течение 15 минут.';
      status.className = 'form-status ok';
      form.reset();
    }, 800);
  });
</script>
